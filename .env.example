# ── Copy to .env for local development ────────────────────────────────────────
# `.env` is git-ignored. These defaults run the app with NO authentication and
# CSV fixtures, so you can iterate without any GCP setup.

# dev | staging | prod
ENV=dev

# Master auth switch. Keep false for fast local work.
AUTH_ENABLED=false

# Flask session signing key (any random string for dev; use Secret Manager in prod)
SESSION_SECRET=dev-insecure-secret-change-me

# ── GCP (only needed when AUTH_ENABLED=true or using real BigQuery) ───────────
GCP_PROJECT_ID=
GCP_REGION=europe-west1

# ── Firebase / Identity Platform (only needed when AUTH_ENABLED=true) ─────────
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
# Leave empty to use Application Default Credentials (recommended on Cloud Run)
FIREBASE_CREDENTIALS_FILE=

# ── BigQuery ──────────────────────────────────────────────────────────────────
BQ_DATASET_PREFIX=client_
# Dataset for the bq_sample dashboard
BQ_SAMPLE_PROJECT=native-analytics-486522
BQ_SAMPLE_DATASET=amazon_2025
BQ_SAMPLE_TABLE=disinformation_timeline
